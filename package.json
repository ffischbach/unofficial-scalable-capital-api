{
  "name": "unofficial-scalable-capital-api",
  "version": "0.1.0",
  "description": "Unofficial local proxy for the Scalable Capital GraphQL API",
  "type": "module",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsc",
    "start": "tsx src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "report-changes": "tsx scripts/report-changes.ts",
    "report-changes:print": "tsx scripts/report-changes.ts --print",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "format": "prettier --write src",
    "format:check": "prettier --check src"
  },
  "dependencies": {
    "@scalar/express-api-reference": "^0.8.46",
    "decimal.js": "^10.4.3",
    "express": "^5.1.0",
    "puppeteer": "^24.3.1",
    "ws": "^8.19.0",
    "yaml": "^2.8.2",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/express": "^5.0.1",
    "@types/node": "^22.13.10",
    "@types/ws": "^8.18.1",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.1",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.57.1",
    "vitest": "^4.0.18"
  }
}
