{
  "__inputs": [
    {
      "name": "DS_SCALABLE",
      "label": "Scalable Capital",
      "description": "Infinity datasource pointing at the local proxy",
      "type": "datasource",
      "pluginId": "yesoreyeram-infinity-datasource",
      "pluginName": "Infinity"
    }
  ],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "12.0.0" },
    { "type": "datasource", "id": "yesoreyeram-infinity-datasource", "name": "Infinity", "version": "3.7.2" },
    { "type": "panel", "id": "stat", "name": "Stat", "version": "" },
    { "type": "panel", "id": "table", "name": "Table", "version": "" }
  ],
  "annotations": { "list": [] },
  "description": "Live portfolio overview powered by the unofficial Scalable Capital API",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": null,
  "links": [],
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Total Portfolio Value",
      "gridPos": { "h": 5, "w": 5, "x": 0, "y": 0 },
      "datasource": { "type": "yesoreyeram-infinity-datasource", "uid": "scalable" },
      "targets": [
        {
          "refId": "A",
          "type": "json",
          "source": "url",
          "url": "http://host.docker.internal:3141/portfolio",
          "url_options": { "method": "GET" },
          "parser": "backend",
          "format": "table",
          "root_selector": "valuation"
        }
      ],
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "decimals": 2,
          "mappings": [],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }] },
          "unit": "currencyEUR"
        },
        "overrides": []
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Securities Valuation",
      "gridPos": { "h": 5, "w": 5, "x": 5, "y": 0 },
      "datasource": { "type": "yesoreyeram-infinity-datasource", "uid": "scalable" },
      "targets": [
        {
          "refId": "A",
          "type": "json",
          "source": "url",
          "url": "http://host.docker.internal:3141/portfolio",
          "url_options": { "method": "GET" },
          "parser": "backend",
          "format": "table",
          "root_selector": "securitiesValuation"
        }
      ],
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "decimals": 2,
          "mappings": [],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }] },
          "unit": "currencyEUR"
        },
        "overrides": []
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Unrealised Return (€)",
      "gridPos": { "h": 5, "w": 5, "x": 10, "y": 0 },
      "datasource": { "type": "yesoreyeram-infinity-datasource", "uid": "scalable" },
      "targets": [
        {
          "refId": "A",
          "type": "json",
          "source": "url",
          "url": "http://host.docker.internal:3141/portfolio",
          "url_options": { "method": "GET" },
          "parser": "backend",
          "format": "table",
          "root_selector": "unrealisedReturn.absoluteUnrealisedReturn"
        }
      ],
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "decimals": 2,
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "red", "value": null }, { "color": "green", "value": 0 }]
          },
          "unit": "currencyEUR"
        },
        "overrides": []
      }
    },
    {
      "id": 6,
      "type": "stat",
      "title": "Unrealised Return (%)",
      "gridPos": { "h": 5, "w": 5, "x": 15, "y": 0 },
      "datasource": { "type": "yesoreyeram-infinity-datasource", "uid": "scalable" },
      "targets": [
        {
          "refId": "A",
          "type": "json",
          "source": "url",
          "url": "http://host.docker.internal:3141/portfolio",
          "url_options": { "method": "GET" },
          "parser": "backend",
          "format": "table",
          "root_selector": "unrealisedReturn.relativeUnrealisedReturn"
        }
      ],
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "decimals": 2,
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "red", "value": null }, { "color": "green", "value": 0 }]
          },
          "unit": "percentunit"
        },
        "overrides": []
      }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Crypto Valuation",
      "gridPos": { "h": 5, "w": 4, "x": 20, "y": 0 },
      "datasource": { "type": "yesoreyeram-infinity-datasource", "uid": "scalable" },
      "targets": [
        {
          "refId": "A",
          "type": "json",
          "source": "url",
          "url": "http://host.docker.internal:3141/portfolio",
          "url_options": { "method": "GET" },
          "parser": "backend",
          "format": "table",
          "root_selector": "cryptoValuation"
        }
      ],
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "decimals": 2,
          "mappings": [],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "purple", "value": null }] },
          "unit": "currencyEUR"
        },
        "overrides": []
      }
    },
    {
      "id": 5,
      "type": "table",
      "title": "Performance by Timeframe",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 5 },
      "datasource": { "type": "yesoreyeram-infinity-datasource", "uid": "scalable" },
      "targets": [
        {
          "refId": "A",
          "type": "json",
          "source": "url",
          "url": "http://host.docker.internal:3141/portfolio",
          "url_options": { "method": "GET" },
          "parser": "backend",
          "format": "table",
          "root_selector": "timeWeightedReturnByTimeframe",
          "columns": [
            { "selector": "timeframe", "text": "Timeframe", "type": "string" },
            { "selector": "simpleAbsoluteReturn", "text": "Absolute Return", "type": "number" }
          ]
        }
      ],
      "options": {
        "cellHeight": "sm",
        "footer": { "show": false },
        "showHeader": true
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "custom": { "align": "auto", "cellOptions": { "type": "auto" } },
          "mappings": [],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Absolute Return" },
            "properties": [
              { "id": "unit", "value": "currencyEUR" },
              { "id": "decimals", "value": 2 }
            ]
          }
        ]
      }
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["scalable-capital", "portfolio"],
  "templating": { "list": [] },
  "time": { "from": "now-6h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "Scalable Capital Portfolio",
  "uid": "scalable-portfolio",
  "version": 5
}